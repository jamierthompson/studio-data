# ============================================================
# StudioData — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env

# Postgres connection (required)
# When running via Docker Compose, the host is the service name "postgres".
# When running locally against Docker, use "localhost".
DATABASE_URL=postgresql://studio:changeme@localhost:5432/studioos
